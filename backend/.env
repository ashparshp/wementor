# Server Configuration
PORT=8080
ENV=development

# Database Configuration (Get this from Supabase Dashboard -> Database -> Connection String -> URI)
# Example: postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres:your_password@db.your-supabase-url.supabase.co:5432/postgres

# Additional services you mentioned in your structure (Add real keys here later)
# RAZORPAY_KEY_ID=your_razorpay_key
# RAZORPAY_KEY_SECRET=your_razorpay_secret
# RESEND_API_KEY=your_resend_api_key
# ZOOM_CLIENT_ID=your_zoom_client_id
# ZOOM_CLIENT_SECRET=your_zoom_client_secret